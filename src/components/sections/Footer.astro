---
import { FOOTER, SOCIAL_LINKS } from '@/constants/content';
import { NAV_LINKS } from '@/constants/navigation';
---

<footer class="footer">
  <div class="container footer__inner">

    <!-- Brand -->
    <div class="footer__brand">
      <div class="footer__logo">
        <div class="footer__logo-mark">P</div>
        <span class="footer__logo-name">Pylon</span>
      </div>
      <p class="footer__description">{FOOTER.description}</p>
      <div class="footer__social">
        {SOCIAL_LINKS.map(link => (
          <a
            href={link.href}
            class="footer__social-link"
            aria-label={link.label}
            target="_blank"
            rel="noopener noreferrer"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Nav links -->
    <nav class="footer__nav" aria-label="Footer navigation">
      <p class="footer__nav-title">Secciones</p>
      {NAV_LINKS.map(link => (
        <a href={link.href} class="footer__nav-link">{link.label}</a>
      ))}
    </nav>

    <!-- Open Source -->
    <div class="footer__oss">
      <p class="footer__nav-title">Contribuye</p>
      <a
        href="https://github.com/pylon-parquecentral/pylon"
        class="footer__nav-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub Repository
      </a>
      <a
        href="https://github.com/pylon-parquecentral/pylon/blob/main/CONTRIBUTING.md"
        class="footer__nav-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        Guía de contribución
      </a>
      <a
        href="https://github.com/pylon-parquecentral/pylon/issues?q=label%3A%22good+first+issue%22"
        class="footer__nav-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        Good first issues
      </a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__tagline">{FOOTER.tagline}</p>
      <p class="footer__copyright">{FOOTER.copyright}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-oscuro);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding: 3.5rem 1.25rem 2rem;
  }

  /* Logo */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.875rem;
  }

  .footer__logo-mark {
    width: 32px;
    height: 32px;
    background: var(--color-edificio);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }

  .footer__logo-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
  }

  .footer__description {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
    margin-bottom: 1.25rem;
  }

  .footer__social {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer__social-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-sm);
    padding: 0.375rem 0.75rem;
    transition: all 0.15s;
  }

  .footer__social-link:hover {
    color: #fff;
    border-color: rgba(255,255,255,0.3);
  }

  /* Nav */
  .footer__nav-title {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.3);
    margin-bottom: 0.875rem;
  }

  .footer__nav,
  .footer__oss {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .footer__nav-link {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    padding: 0.375rem 0;
    transition: color 0.15s;
  }

  .footer__nav-link:hover { color: #fff; }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1.25rem;
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
  }

  .footer__copyright {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
</style>
