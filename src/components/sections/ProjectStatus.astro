---
import Badge from '@/components/ui/Badge.astro';
import { PROJECT_ROADMAP, TECH_STACK, DEPLOY_TIMELINE } from '@/constants/content';
import type { RoadmapStatus } from '@/types';

const statusLabel: Record<RoadmapStatus, string> = {
  'completed':   'Listo',
  'in-progress': 'En progreso',
  'planned':     'Planeado',
};

const statusVariant: Record<RoadmapStatus, 'success' | 'pending' | 'planned'> = {
  'completed':   'success',
  'in-progress': 'pending',
  'planned':     'planned',
};

const deployStatusLabel: Record<string, string> = {
  active:   'En curso',
  done:     'Completado',
  upcoming: 'Próximo',
};
---

<!-- ── Estado del Proyecto — sticky horizontal scroll ─── -->
<section id="estado" class="status-section">
  <div class="status-sticky" id="status-sticky">

    <!-- Barra de progreso -->
    <div class="status__progress-bar" aria-hidden="true">
      <div class="status__progress-fill" id="status-progress-fill"></div>
    </div>

    <!-- Header -->
    <div class="status__header">
      <p class="section-label section-label--light">Transparencia</p>
      <h2 class="status__title">Estado del Proyecto</h2>
      <p class="status__subtitle">
        No es solo una idea. Aquí puedes ver exactamente en qué estamos trabajando y qué viene después.
      </p>
    </div>

    <!-- Cards track -->
    <div class="status__overflow">
      <div class="status__track" id="status-track">
        {PROJECT_ROADMAP.map((phase, i) => (
          <article
            class={`status-card status-card--${phase.status}`}
            style={`--i:${i}`}
          >
            <span class="status-card__num">0{phase.phase}</span>
            <h3 class="status-card__name">{phase.name}</h3>
            <p class="status-card__desc">{phase.description}</p>
            <div class="status-card__foot">
              <Badge variant={statusVariant[phase.status]}>
                {statusLabel[phase.status]}
              </Badge>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Hint -->
    <p class="status__hint" id="status-hint" aria-hidden="true">
      <span class="status__hint-arrow">↓</span> desplázate para ver más
    </p>

    <div class="container">
    <p class="section-label section-label--light" style="margin-bottom:1.25rem;">Stack Tecnológico</p>
    <div class="tech-stack__grid">
      {TECH_STACK.map(tech => (
        <div class="tech-stack__item">
          <img src={tech.logo} alt={tech.name} width="28" height="28" loading="lazy" onerror="this.style.display='none'" />
          <span class="tech-stack__name">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
  </div>
</section>

<!-- ── Plan de Despliegue — timeline full-width ────────── -->
<section class="deploy" id="deploy-section">

  <!-- Header centrado -->
  <div class="deploy__header">
    <p class="section-label section-label--light">Plan de Despliegue</p>
    <h2 class="deploy__title">Del servidor a 10.000 personas</h2>
    <p class="deploy__subtitle">
      Un plan de 5 semanas para pasar de la infra al condominio completo — con criterios de avance claros en cada fase.
    </p>
  </div>

  <!-- Timeline — línea y nodos cubren todo el ancho -->
  <div class="tl" id="tl">

    <!-- Línea base (siempre visible, tenue) -->
    <div class="tl__base"  aria-hidden="true"></div>
    <!-- Línea animada (entra de izquierda a derecha) -->
    <div class="tl__fill"  aria-hidden="true"></div>

    <!-- Fases centradas en max-width, nodos sobre la línea -->
    <div class="tl__phases">
      {DEPLOY_TIMELINE.map((phase, i) => (
        <div
          class={`tl__phase tl__phase--${phase.status}`}
          style={`--i:${i}`}
          data-week={phase.week}
        >
          <!-- Etiqueta + tick hacia abajo -->
          <div class="tl__above">
            <span class="tl__week">{phase.week}</span>
            <div class="tl__tick" aria-hidden="true"></div>
          </div>

          <!-- Nodo sobre la línea -->
          <div class="tl__node-wrap">
            <div class="tl__node">
              {phase.status === 'active' && (
                <div class="tl__pulse" aria-hidden="true"></div>
              )}
            </div>
          </div>

          <!-- Contenido bajo el nodo -->
          <div class="tl__below">
            <div class="tl__tick tl__tick--down" aria-hidden="true"></div>
            <h3 class="tl__name" data-week={phase.week}>{phase.title}</h3>
            {phase.metric && <p class="tl__metric">{phase.metric}</p>}
            <p class="tl__desc">{phase.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>

</section>

<style>
  /* ─────────────────────────────────────────────────────
     ESTADO — sticky horizontal scroll
  ───────────────────────────────────────────────────── */
  .status-section {
    height: 280vh;
    position: relative;
  }

  .status-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
    overflow: hidden;
  }

  /* Barra de progreso */
  .status__progress-bar {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: rgba(255,255,255,0.06);
  }
  .status__progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-edificio), var(--color-parque));
    transition: width 0.05s linear;
  }

  /* Header */
  .status__header {
    max-width: 1120px;
    margin: 0 auto;
    width: 100%;
  }

  .status__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0.5rem 0 0.75rem;
  }

  .status__subtitle {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.4);
    max-width: 500px;
  }

  /* Overflow + track */
  .status__overflow {
    overflow: hidden;
    width: 100%;
  }

  .status__track {
    display: flex;
    gap: 1.25rem;
    padding: 0.5rem 2.5rem;
    will-change: transform;
  }

  /* Hint */
  .status__hint {
    text-align: center;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.18);
    transition: opacity 0.4s;
  }

  .status__hint-arrow {
    display: inline-block;
    animation: bounce 1.6s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }

  /* ─────────────────────────────────────────────────────
     STATUS CARDS (roadmap)
  ───────────────────────────────────────────────────── */
  .status-card {
    flex-shrink: 0;
    width: 260px;
    min-height: 260px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-top: 3px solid rgba(255,255,255,0.1);
    border-radius: 14px;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .status-card--completed   { border-top-color: var(--color-parque); }
  .status-card--in-progress {
    border-top-color: var(--color-edificio);
    background: rgba(201,84,30,0.06);
  }

  .status-card__num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: rgba(255,255,255,0.1);
    margin-bottom: 0.25rem;
  }
  .status-card--completed   .status-card__num { color: rgba(62,122,60,0.35); }
  .status-card--in-progress .status-card__num { color: rgba(201,84,30,0.4); }

  .status-card__name {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: rgba(255,255,255,0.88);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .status-card__desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.38);
    flex: 1;
  }

  .status-card__foot {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  /* ─────────────────────────────────────────────────────
     TECH STACK
  ───────────────────────────────────────────────────── */
  .tech-section {
    background: #0d0d0d;
    padding: 3.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .tech-stack__grid { display: flex; flex-wrap: wrap; gap: 0.625rem; }
  .tech-stack__item {
    display: flex; align-items: center; gap: 0.5rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem; font-weight: 600;
    color: rgba(255,255,255,0.65);
  }
  .tech-stack__name { white-space: nowrap; }
  .tech-stack__item img {
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }

  /* ─────────────────────────────────────────────────────
     DEPLOY SECTION — timeline full-width
  ───────────────────────────────────────────────────── */
  .deploy {
    background: #0d0d0d;
    padding: 5rem 0 6rem;
    overflow: hidden;
  }

  .deploy__header {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2.5rem 4.5rem;
  }

  .deploy__title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0.5rem 0 0.875rem;
  }

  .deploy__subtitle {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.4);
    max-width: 520px;
  }

  /* ─────────────────────────────────────────────────────
     TIMELINE
     Estructura vertical por fase:
       .tl__above  → 72px fijos (semana + tick ↓)
       .tl__node-wrap → 24px  (centro en y = 72+12 = 84px)
       .tl__below  → contenido
     Las líneas .tl__base/.tl__fill van top:84px edge-to-edge
  ───────────────────────────────────────────────────── */
  .tl {
    position: relative;
    width: 100%;
  }

  /* Líneas horizontales — cubren todo el ancho */
  .tl__base,
  .tl__fill {
    position: absolute;
    top: 84px;   /* 72px (above) + 12px (½ node-wrap 24px) */
    left: 0;
    right: 0;
    height: 1px;
    pointer-events: none;
  }
  .tl__base { background: rgba(255,255,255,0.07); z-index: 0; }
  .tl__fill {
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(201,84,30,0.9) 10%,
      rgba(201,84,30,0.5) 50%,
      rgba(62,122,60,0.5) 88%,
      transparent 100%
    );
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 1.8s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 1;
  }

  /* Fases — centradas, max-width */
  .tl__phases {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  /* Fase individual */
  .tl__phase {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: calc(var(--i) * 170ms + 400ms);
  }

  /* ── Área superior: semana + tick ─── */
  .tl__above {
    height: 72px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
  }

  .tl__week {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255,255,255,0.28);
    white-space: nowrap;
    margin-bottom: 8px;
  }
  .tl__phase--active .tl__week { color: var(--color-edificio); }

  .tl__tick {
    width: 1px;
    height: 10px;
    background: rgba(255,255,255,0.12);
    flex-shrink: 0;
  }
  .tl__tick--down   { height: 12px; margin-bottom: 10px; }
  .tl__phase--active .tl__tick { background: rgba(201,84,30,0.5); }

  /* ── Nodo ─────────────────────────── */
  .tl__node-wrap {
    position: relative;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    flex-shrink: 0;
  }

  .tl__node {
    border-radius: 50%;
    position: relative;
    transform: scale(0);
    transition: transform 0.42s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: calc(var(--i) * 170ms + 700ms);
  }
  .tl__phase--done     .tl__node { width: 10px; height: 10px; background: var(--color-parque); }
  .tl__phase--active   .tl__node { width: 14px; height: 14px; background: var(--color-edificio); box-shadow: 0 0 0 4px rgba(201,84,30,0.18); }
  .tl__phase--upcoming .tl__node { width: 10px; height: 10px; background: transparent; border: 1.5px solid rgba(255,255,255,0.18); }

  .tl__pulse {
    position: absolute;
    inset: -9px;
    border-radius: 50%;
    border: 1px solid rgba(201,84,30,0.45);
    animation: tlPulse 2.4s ease-in-out infinite;
  }

  @keyframes tlPulse {
    0%, 100% { transform: scale(0.6); opacity: 0.7; }
    50%       { transform: scale(1.5); opacity: 0; }
  }

  /* ── Contenido inferior ──────────── */
  .tl__below {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 155px;
  }

  .tl__name {
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    color: rgba(255,255,255,0.85);
    white-space: nowrap;
    margin-bottom: 0.3rem;
  }

  .tl__metric {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--color-edificio);
    margin-bottom: 0.4rem;
  }
  .tl__phase--upcoming .tl__metric { color: rgba(255,255,255,0.25); }

  .tl__desc {
    font-size: 0.6875rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.3);
  }

  /* ── Animaciones al entrar en viewport ── */
  .deploy.is-visible .tl__fill    { transform: scaleX(1); }
  .deploy.is-visible .tl__phase   { opacity: 1; transform: translateY(0); }
  .deploy.is-visible .tl__node    { transform: scale(1); }

  /* ─────────────────────────────────────────────────────
     MOBILE
  ───────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    /* Status section */
    .status-section { height: auto; }
    .status-sticky  { position: static; height: auto; padding: 4rem 0; gap: 1.5rem; }
    .status__progress-bar { display: none; }
    .status__header { padding: 0 1.25rem; }
    .status__overflow {
      overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none;
    }
    .status__overflow::-webkit-scrollbar { display: none; }
    .status__track  { transform: none !important; padding: 0.5rem 1.25rem 1rem; }
    .status-card    { width: 210px; min-height: auto; }
    .status__hint   { display: none; }

    /* Deploy timeline → lista vertical */
    .deploy { padding: 4rem 0 5rem; }
    .deploy__header { padding: 0 1.25rem 3rem; }
    .tl__base, .tl__fill { display: none; }

    .tl__phases {
      flex-direction: column;
      padding: 0 1.25rem;
      gap: 0;
    }

    .tl__phase {
      flex-direction: row;
      align-items: flex-start;
      gap: 1rem;
      padding-bottom: 2rem;
      position: relative;
    }

    /* Línea vertical entre fases */
    .tl__phase:not(:last-child)::after {
      content: '';
      position: absolute;
      left: calc(1.25rem + 11px);
      top: 28px; bottom: 0;
      width: 1px;
      background: rgba(255,255,255,0.07);
    }

    .tl__above    { display: none; }
    .tl__node-wrap { margin-top: 2px; flex-shrink: 0; }
    .tl__below    { align-items: flex-start; text-align: left; max-width: none; flex: 1; }
    .tl__tick--down { display: none; }

    /* Semana como prefijo del título */
    .tl__name::before {
      content: attr(data-week) ' · ';
      font-weight: 400;
      color: rgba(255,255,255,0.28);
      font-size: 0.6875rem;
      font-family: var(--font-body);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .status__hint-arrow { animation: none; }
    .status__track { transition: none !important; }
    .tl__fill, .tl__phase, .tl__node { transition: none; }
    .tl__pulse { animation: none; }
    .deploy.is-visible .tl__fill  { transform: scaleX(1); }
    .deploy.is-visible .tl__phase { opacity: 1; transform: none; }
    .deploy.is-visible .tl__node  { transform: scale(1); }
  }
</style>

<script>
  const section = document.getElementById('estado')             as HTMLElement | null;
  const track   = document.getElementById('status-track')       as HTMLElement | null;
  const pfill   = document.getElementById('status-progress-fill') as HTMLElement | null;
  const hint    = document.getElementById('status-hint')        as HTMLElement | null;

  if (!section || !track) throw 0;

  const isMobile = () => window.innerWidth <= 767;

  // Caché de métricas para no recalcular en cada frame
  let metrics = { startX: 0, endX: 0, scrollRange: 0 };

  function calcMetrics() {
    const overflow     = track.parentElement as HTMLElement;
    const trackWidth   = track.scrollWidth;
    const visibleWidth = overflow.offsetWidth;
    metrics = {
      startX:      visibleWidth,          // empieza completamente fuera a la derecha
      endX:        -(trackWidth - visibleWidth + 48),
      scrollRange: section.offsetHeight - window.innerHeight,
    };
  }

  function update() {
    if (isMobile()) {
      track.style.transform = '';
      return;
    }

    const { scrollRange, startX, endX } = metrics;
    if (scrollRange <= 0) return;

    // rect.top = 0 cuando el borde superior de la sección toca el tope del viewport.
    // Se vuelve negativo a medida que scrolleamos; -rect.top = px scrolleados dentro de la sección.
    const progress = Math.max(0, Math.min(1, -section.getBoundingClientRect().top / scrollRange));

    track.style.transform = `translateX(${startX + (endX - startX) * progress}px)`;

    if (pfill) pfill.style.width  = `${progress * 100}%`;
    if (hint)  hint.style.opacity = progress > 0.04 ? '0' : '1';
  }

  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', () => { calcMetrics(); update(); });

  // Primer cálculo una vez que el layout esté listo
  requestAnimationFrame(() => { calcMetrics(); update(); });

  // ── Deploy timeline: IntersectionObserver ──────────
  const deploySection = document.getElementById('deploy-section');
  if (deploySection) {
    const io = new IntersectionObserver(
      entries => {
        if (entries[0].isIntersecting) {
          entries[0].target.classList.add('is-visible');
          io.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    io.observe(deploySection);
  }
</script>
