---
import Badge from '@/components/ui/Badge.astro';
import { PROJECT_ROADMAP, TECH_STACK, DEPLOY_TIMELINE } from '@/constants/content';
import type { RoadmapStatus } from '@/types';
import '@/styles/sections/project-status.css';

const statusLabel: Record<RoadmapStatus, string> = {
  'completed':   'Listo',
  'in-progress': 'En progreso',
  'planned':     'Planeado',
};

const statusVariant: Record<RoadmapStatus, 'success' | 'pending' | 'planned'> = {
  'completed':   'success',
  'in-progress': 'pending',
  'planned':     'planned',
};

const deployStatusLabel: Record<string, string> = {
  active:   'En curso',
  done:     'Completado',
  upcoming: 'Próximo',
};
---

<!-- ── Estado del Proyecto — sticky horizontal scroll ─── -->
<section id="estado" class="status-section">
  <div class="status-sticky" id="status-sticky">

    <!-- Barra de progreso -->
    <div class="status__progress-bar" aria-hidden="true">
      <div class="status__progress-fill" id="status-progress-fill"></div>
    </div>

    <!-- Header -->
    <div class="status__header">
      <p class="section-label section-label--light">Transparencia</p>
      <h2 class="status__title">Estado del Proyecto</h2>
      <p class="status__subtitle">
        No es solo una idea. Aquí puedes ver exactamente en qué estamos trabajando y qué viene después.
      </p>
    </div>

    <!-- Cards track -->
    <div class="status__overflow">
      <div class="status__track" id="status-track">
        {PROJECT_ROADMAP.map((phase, i) => (
          <article
            class={`status-card status-card--${phase.status}`}
            style={`--i:${i}`}
          >
            <span class="status-card__num">0{phase.phase}</span>
            <h3 class="status-card__name">{phase.name}</h3>
            <p class="status-card__desc">{phase.description}</p>
            <div class="status-card__foot">
              <Badge variant={statusVariant[phase.status]}>
                {statusLabel[phase.status]}
              </Badge>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Hint -->
    <p class="status__hint" id="status-hint" aria-hidden="true">
      <span class="status__hint-arrow">↓</span> desplázate para ver más
    </p>

    <div class="container">
    <p class="section-label section-label--light" style="margin-bottom:1.25rem;">Stack Tecnológico</p>
    <div class="tech-stack__grid">
      {TECH_STACK.map(tech => (
        <div class="tech-stack__item">
          <img src={tech.logo} alt={tech.name} width="28" height="28" loading="lazy" onerror="this.style.display='none'" />
          <span class="tech-stack__name">{tech.name}</span>
        </div>
      ))}
    </div>
  </div>
  </div>
</section>

<!-- ── Plan de Despliegue — timeline full-width ────────── -->
<section class="deploy" id="deploy-section">

  <!-- Header centrado -->
  <div class="deploy__header">
    <p class="section-label section-label--light">Plan de Despliegue</p>
    <h2 class="deploy__title">Del servidor a 10.000 personas</h2>
    <p class="deploy__subtitle">
      Un plan de 5 semanas para pasar de la infra al condominio completo — con criterios de avance claros en cada fase.
    </p>
  </div>

  <!-- Timeline — línea y nodos cubren todo el ancho -->
  <div class="tl" id="tl">

    <!-- Línea base (siempre visible, tenue) -->
    <div class="tl__base"  aria-hidden="true"></div>
    <!-- Línea animada (entra de izquierda a derecha) -->
    <div class="tl__fill"  aria-hidden="true"></div>

    <!-- Fases centradas en max-width, nodos sobre la línea -->
    <div class="tl__phases">
      {DEPLOY_TIMELINE.map((phase, i) => (
        <div
          class={`tl__phase tl__phase--${phase.status}`}
          style={`--i:${i}`}
          data-week={phase.week}
        >
          <!-- Etiqueta + tick hacia abajo -->
          <div class="tl__above">
            <span class="tl__week">{phase.week}</span>
            <div class="tl__tick" aria-hidden="true"></div>
          </div>

          <!-- Nodo sobre la línea -->
          <div class="tl__node-wrap">
            <div class="tl__node">
              {phase.status === 'active' && (
                <div class="tl__pulse" aria-hidden="true"></div>
              )}
            </div>
          </div>

          <!-- Contenido bajo el nodo -->
          <div class="tl__below">
            <div class="tl__tick tl__tick--down" aria-hidden="true"></div>
            <h3 class="tl__name" data-week={phase.week}>{phase.title}</h3>
            {phase.metric && <p class="tl__metric">{phase.metric}</p>}
            <p class="tl__desc">{phase.description}</p>
          </div>
        </div>
      ))}
    </div>

  </div>

</section>

<script>
  const section = document.getElementById('estado')             as HTMLElement | null;
  const track   = document.getElementById('status-track')       as HTMLElement | null;
  const pfill   = document.getElementById('status-progress-fill') as HTMLElement | null;
  const hint    = document.getElementById('status-hint')        as HTMLElement | null;

  if (!section || !track) throw 0;

  const isMobile = () => window.innerWidth <= 767;

  // Caché de métricas para no recalcular en cada frame
  let metrics = { startX: 0, endX: 0, scrollRange: 0 };

  function calcMetrics() {
    const overflow     = track.parentElement as HTMLElement;
    const trackWidth   = track.scrollWidth;
    const visibleWidth = overflow.offsetWidth;
    metrics = {
      startX:      visibleWidth,          // empieza completamente fuera a la derecha
      endX:        -(trackWidth - visibleWidth + 48),
      scrollRange: section.offsetHeight - window.innerHeight,
    };
  }

  function update() {
    if (isMobile()) {
      track.style.transform = '';
      return;
    }

    const { scrollRange, startX, endX } = metrics;
    if (scrollRange <= 0) return;

    // rect.top = 0 cuando el borde superior de la sección toca el tope del viewport.
    // Se vuelve negativo a medida que scrolleamos; -rect.top = px scrolleados dentro de la sección.
    const progress = Math.max(0, Math.min(1, -section.getBoundingClientRect().top / scrollRange));

    track.style.transform = `translateX(${startX + (endX - startX) * progress}px)`;

    if (pfill) pfill.style.width  = `${progress * 100}%`;
    if (hint)  hint.style.opacity = progress > 0.04 ? '0' : '1';
  }

  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', () => { calcMetrics(); update(); });

  // Primer cálculo una vez que el layout esté listo
  requestAnimationFrame(() => { calcMetrics(); update(); });

  // ── Deploy timeline: IntersectionObserver ──────────
  const deploySection = document.getElementById('deploy-section');
  if (deploySection) {
    const io = new IntersectionObserver(
      entries => {
        if (entries[0].isIntersecting) {
          entries[0].target.classList.add('is-visible');
          io.disconnect();
        }
      },
      { threshold: 0.15 }
    );
    io.observe(deploySection);
  }
</script>
