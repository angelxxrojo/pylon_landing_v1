---
import { HOW_TO_STEPS } from '@/constants/content';
---

<section id="como-empezar" class="how-section">

  <!-- Header split -->
  <div class="how__header">
    <div class="how__header-left">
      <p class="how__eyebrow">El Proceso</p>
      <h2 class="how__title">¿Cómo empezar?</h2>
    </div>
    <div class="how__header-right">
      <p class="how__subtitle">
        Cuatro pasos simples. No necesitas que nadie te invite — el proyecto es abierto.
      </p>
      <button type="button" data-join-trigger class="how__cta">
        Quiero unirme
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Divider line -->
  <div class="how__divider" aria-hidden="true"></div>

  <!-- Steps grid -->
  <div class="how__steps">
    {HOW_TO_STEPS.map((step, i) => (
      <article class="how__step">

        <!-- Número decorativo de fondo -->
        <span class="how__step-bg" aria-hidden="true">{step.step}</span>

        <!-- Tope: step label -->
        <div class="how__step-top">
          <span class="how__step-badge">{step.step}</span>
        </div>

        <!-- Contenido -->
        <div class="how__step-body">
          <h3 class="how__step-title">{step.title}</h3>
          <p class="how__step-desc">{step.description}</p>
        </div>

        <!-- Link -->
        <a
          href={step.cta.href}
          class="how__step-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          {step.cta.label}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>

      </article>
    ))}
  </div>

</section>

<style>
  /* ── Sección ─────────────────────────────────────── */
  .how-section {
    background: #0d0d0d;
    padding: 5rem 0 6rem;
  }

  /* ── Header ──────────────────────────────────────── */
  .how__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2.5rem 3rem;
  }

  .how__eyebrow {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-edificio);
    margin-bottom: 0.75rem;
  }

  .how__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.025em;
  }

  .how__header-right {
    max-width: 380px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .how__subtitle {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.4);
  }

  /* ── CTA button ──────────────────────────────────── */
  .how__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    background: var(--color-edificio);
    color: #fff;
    border: none;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-display);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s, gap 0.2s;
    white-space: nowrap;
  }

  .how__cta:hover {
    opacity: 0.88;
    gap: 0.875rem;
  }

  /* ── Divider ─────────────────────────────────────── */
  .how__divider {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2.5rem;
    height: 1px;
    background: rgba(255,255,255,0.08);
  }

  /* ── Steps grid ──────────────────────────────────── */
  .how__steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 2.5rem;
    /* divisores entre steps */
    divide-x: 1px solid rgba(255,255,255,0.08);
  }

  /* ── Step card ───────────────────────────────────── */
  .how__step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 2.5rem 2rem 2rem;
    overflow: hidden;
    border-left: 1px solid rgba(255,255,255,0.08);
    transition: background 0.25s;
  }

  .how__step:first-child {
    border-left: none;
  }

  .how__step:hover {
    background: rgba(255,255,255,0.025);
  }

  /* Número grande decorativo de fondo */
  .how__step-bg {
    position: absolute;
    bottom: -0.5rem;
    right: 0.75rem;
    font-family: var(--font-display);
    font-size: 7rem;
    font-weight: 900;
    line-height: 1;
    color: rgba(255,255,255,0.03);
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.04em;
  }

  /* Badge del número */
  .how__step-top {
    margin-bottom: 1.75rem;
  }

  .how__step-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid rgba(255,255,255,0.15);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255,255,255,0.5);
    letter-spacing: 0.04em;
  }

  /* Accentúa el primer step */
  .how__step:first-child .how__step-badge {
    border-color: var(--color-edificio);
    color: var(--color-edificio);
  }

  /* Contenido */
  .how__step-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-bottom: 1.5rem;
  }

  .how__step-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    line-height: 1.3;
  }

  .how__step-desc {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.35);
  }

  /* Link */
  .how__step-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s, gap 0.2s;
    position: relative;
    z-index: 1;
    margin-top: auto;
  }

  .how__step-link:hover {
    color: var(--color-edificio);
    gap: 0.625rem;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1023px) {
    .how__steps {
      grid-template-columns: repeat(2, 1fr);
    }

    .how__step:nth-child(odd) {
      border-left: none;
    }

    .how__step:nth-child(n+3) {
      border-top: 1px solid rgba(255,255,255,0.08);
    }
  }

  @media (max-width: 767px) {
    .how__header {
      flex-direction: column;
      align-items: flex-start;
      padding-bottom: 2.5rem;
    }

    .how__header-right {
      max-width: 100%;
    }
  }

  @media (max-width: 599px) {
    .how-section { padding: 4rem 0 5rem; }

    .how__header {
      padding: 0 1.5rem 2rem;
    }

    .how__divider {
      padding: 0 1.5rem;
    }

    .how__steps {
      grid-template-columns: 1fr;
      padding: 0 1.5rem;
    }

    .how__step {
      border-left: none;
      border-top: 1px solid rgba(255,255,255,0.08);
      padding: 2rem 0;
    }

    .how__step:first-child {
      border-top: none;
    }
  }
</style>
