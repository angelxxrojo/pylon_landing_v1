---
import { BENEFITS } from '@/constants/content';
import '@/styles/sections/benefits.css';

const colorMap = {
  edificio: { bg: 'var(--color-edificio-tint)', text: 'var(--color-edificio)' },
  parque:   { bg: 'var(--color-parque-tint)',   text: 'var(--color-parque)'   },
  club:     { bg: 'var(--color-club-tint)',      text: '#185a64'               },
  acento:   { bg: 'var(--color-acento-tint)',    text: 'var(--color-acento)'   },
};

const iconPaths: Record<string, string> = {
  users:          'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm10 14v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  briefcase:      'M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2',
  zap:            'M13 2 3 14h9l-1 8 10-12h-9l1-8z',
  'graduation-cap': 'M22 10v6M2 10l10-5 10 5-10 5-10-5zm10 5v7M12 15l-8-4v6a8 8 0 0 0 16 0v-6l-8 4z',
};
---

<section id="beneficios" class="section-wrapper section-benefits">
  <div class="container">

    <div class="benefits__header">
      <p class="section-label section-label--light">¿Para qué?</p>
      <h2 class="type-h1" style="color:#fff;">Beneficios de sumarse</h2>
      <p class="benefits__subtitle">
        Contribuir al proyecto no es solo una buena acción. Es una inversión en tu carrera y en tu comunidad.
      </p>
    </div>

    <div class="benefits__grid">
      {BENEFITS.map(benefit => {
        const color = colorMap[benefit.color];
        const iconPath = iconPaths[benefit.icon] ?? '';
        return (
          <div class="benefit-card">
            <h3 class="benefit-card__title">{benefit.title}</h3>
            <p class="benefit-card__desc">{benefit.description}</p>
          </div>
        );
      })}
    </div>

  </div>
</section>
