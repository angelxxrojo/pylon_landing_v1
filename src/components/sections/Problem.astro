---
import { PROBLEM } from '@/constants/content';
---

<section id="problema" class="problem">

  <!-- Columna izquierda — problema -->
  <div class="problem__col problem__col--dark">
    <div class="problem__col-inner">
      <p class="problem__label problem__label--dim">{PROBLEM.label}</p>
      <h2 class="problem__title problem__title--light">{PROBLEM.title}</h2>
      <p class="problem__desc problem__desc--light">{PROBLEM.description}</p>

      <ul class="problem__pain-list">
        {PROBLEM.painPoints.map(point => (
          <li class="problem__pain-item">
            <span class="problem__pain-icon" aria-hidden="true">✕</span>
            <span>{point.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Columna derecha — solución -->
  <div class="problem__col problem__col--light">
    <div class="problem__col-inner">
      <p class="problem__label problem__label--brand">{PROBLEM.solution.label}</p>
      <h2 class="problem__title problem__title--dark">{PROBLEM.solution.title}</h2>
      <p class="problem__desc problem__desc--dark">{PROBLEM.solution.description}</p>

      <div class="problem__oss-note">
        <p class="problem__oss-text">{PROBLEM.openSourceNote}</p>
      </div>
    </div>
  </div>

</section>

<style>
  /* ── Layout split ───────────────────────────────── */
  .problem {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  .problem__col {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .problem__col--dark  { background: #350202; }
  .problem__col--light { background: #ffffff; }

  .problem__col-inner {
    width: 100%;
    max-width: 520px;
    padding: 5rem 3rem;
  }

  /* ── Labels ─────────────────────────────────────── */
  .problem__label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }
  .problem__label--dim   { color: rgba(255,255,255,0.35); }
  .problem__label--brand { color: var(--color-edificio); }

  /* ── Titles ─────────────────────────────────────── */
  .problem__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 2.25rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }
  .problem__title--light { color: #ffffff; }
  .problem__title--dark  { color: var(--color-oscuro); }

  /* ── Body text ──────────────────────────────────── */
  .problem__desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .problem__desc--light { color: rgba(255,255,255,0.6); }
  .problem__desc--dark  { color: var(--color-texto); }

  /* ── Pain list ──────────────────────────────────── */
  .problem__pain-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .problem__pain-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
  }

  .problem__pain-icon {
    width: 26px;
    height: 26px;
    background: rgba(190,30,45,0.25);
    color: #ff6b6b;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ── Open source note ───────────────────────────── */
  .problem__oss-note {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    background: var(--color-fondo);
    border-left: 3px solid var(--color-parque);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: 1rem 1.25rem;
    margin-top: 2rem;
  }

  .problem__oss-icon {
    font-size: 1.125rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .problem__oss-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-texto);
  }

  /* ── Mobile: apilado ────────────────────────────── */
  @media (max-width: 767px) {
    .problem {
      grid-template-columns: 1fr;
    }
    .problem__col-inner {
      padding: 3.5rem 1.5rem;
    }
  }
</style>
