---
import { PROBLEM } from '@/constants/content';
import '@/styles/sections/problem.css';
---

<section id="problema" class="problem">

  <!-- Columna izquierda — problema -->
  <div class="problem__col problem__col--dark">
    <div class="problem__col-inner">
      <p class="problem__label problem__label--dim">{PROBLEM.label}</p>
      <h2 class="problem__title problem__title--light">{PROBLEM.title}</h2>
      <p class="problem__desc problem__desc--light">{PROBLEM.description}</p>

      <ul class="problem__pain-list">
        {PROBLEM.painPoints.map(point => (
          <li class="problem__pain-item">
            <span class="problem__pain-icon" aria-hidden="true">✕</span>
            <span>{point.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Columna derecha — solución -->
  <div class="problem__col problem__col--light">
    <div class="problem__col-inner">
      <p class="problem__label problem__label--brand">{PROBLEM.solution.label}</p>
      <h2 class="problem__title problem__title--dark">{PROBLEM.solution.title}</h2>
      <p class="problem__desc problem__desc--dark">{PROBLEM.solution.description}</p>

      <div class="problem__oss-note">
        <p class="problem__oss-text">{PROBLEM.openSourceNote}</p>
      </div>
    </div>
  </div>

</section>
