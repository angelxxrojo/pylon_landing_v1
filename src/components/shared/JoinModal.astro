---
import { TEAM_ROLES } from '@/constants/content';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? '';
---

<div id="join-modal" class="jm" role="dialog" aria-modal="true" aria-labelledby="jm-title" hidden>

  <div class="jm__overlay" id="jm-overlay"></div>

  <div class="jm__panel">

    <!-- Líneas decorativas (crosshair aesthetic) -->
    <div class="jm__deco" aria-hidden="true">
      <div class="jm__deco-h"></div>
      <div class="jm__deco-v"></div>
    </div>

    <!-- Header -->
    <div class="jm__header">
      <p class="jm__label">Pylon · Parque Central</p>
      <h2 id="jm-title" class="jm__title">Quiero unirme</h2>
      <p class="jm__subtitle">Completa el formulario y te contactamos pronto.</p>
    </div>

    <!-- Formulario -->
    <form
      id="join-form"
      class="jm__form"
      data-endpoint={`https://formspree.io/f/${formspreeId}`}
      novalidate
    >

      <div class="jm__row jm__row--two">
        <div class="jm__field">
          <label class="jm__label-field" for="f-nombre">Nombre completo <span aria-hidden="true">*</span></label>
          <input
            id="f-nombre"
            name="nombre"
            type="text"
            class="jm__input"
            placeholder="Juan Pérez"
            required
            autocomplete="name"
          />
        </div>
        <div class="jm__field">
          <label class="jm__label-field" for="f-apt">Torre y Apartamento <span aria-hidden="true">*</span></label>
          <input
            id="f-apt"
            name="apartamento"
            type="text"
            class="jm__input"
            placeholder="Torre A – 503"
            required
          />
        </div>
      </div>

      <div class="jm__field">
        <label class="jm__label-field" for="f-email">Correo electrónico <span aria-hidden="true">*</span></label>
        <input
          id="f-email"
          name="email"
          type="email"
          class="jm__input"
          placeholder="juan@correo.com"
          required
          autocomplete="email"
        />
      </div>

      <div class="jm__field">
        <label class="jm__label-field" for="f-rol">Rol de interés <span aria-hidden="true">*</span></label>
        <div class="jm__select-wrap">
          <select id="f-rol" name="rol" class="jm__select" required>
            <option value="" disabled selected>Elige un rol…</option>
            {TEAM_ROLES.map(role => (
              <option value={role.title}>{role.title}</option>
            ))}
          </select>
          <svg class="jm__select-icon" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>

      <div class="jm__field">
        <label class="jm__label-field" for="f-mensaje">Mensaje <span class="jm__optional">(opcional)</span></label>
        <textarea
          id="f-mensaje"
          name="mensaje"
          class="jm__textarea"
          placeholder="Cuéntanos algo sobre ti o cómo quieres contribuir…"
          rows="3"
        ></textarea>
      </div>

      <!-- Estado: error -->
      <p id="jm-error" class="jm__status jm__status--error" hidden>
        Hubo un error al enviar. Intenta de nuevo.
      </p>

      <div class="jm__actions">
        <button type="submit" class="jm__submit" id="jm-submit">
          <span id="jm-submit-label">Enviar solicitud</span>
          <svg id="jm-spinner" class="jm__spinner" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" hidden>
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2.5" stroke-dasharray="50" stroke-dashoffset="15"/>
          </svg>
        </button>
        <button type="button" class="jm__cancel" id="jm-cancel">Cancelar</button>
      </div>
    </form>

    <!-- Estado: éxito -->
    <div id="jm-success" class="jm__success" hidden>
      <div class="jm__success-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"/>
        </svg>
      </div>
      <h3 class="jm__success-title">¡Solicitud enviada!</h3>
      <p class="jm__success-body">Gracias por querer unirte. Revisaremos tu información y te escribiremos pronto.</p>
      <button type="button" class="jm__cancel" id="jm-success-close">Cerrar</button>
    </div>

    <!-- Botón cerrar -->
    <button class="jm__close" id="jm-close" aria-label="Cerrar modal">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>

  </div>
</div>

<style>
  /* ── Overlay ─────────────────────────────────────── */
  .jm {
    position: fixed;
    inset: 0;
    z-index: 9000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
  }

  .jm[hidden] { display: none; }

  .jm__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    cursor: pointer;
  }

  /* ── Panel ───────────────────────────────────────── */
  .jm__panel {
    position: relative;
    z-index: 1;
    background: #111;
    border: 1px solid rgba(255,255,255,0.1);
    width: 100%;
    max-width: 540px;
    max-height: 92dvh;
    overflow-y: auto;
    padding: 2.5rem 2.5rem 2rem;
    animation: jm-in 0.22s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  @keyframes jm-in {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: none; }
  }

  /* ── Decoración crosshair ────────────────────────── */
  .jm__deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.4;
  }
  .jm__deco-h {
    position: absolute;
    left: 0; right: 0;
    top: 30%;
    height: 1px;
    background: rgba(255,255,255,0.08);
  }
  .jm__deco-v {
    position: absolute;
    top: 0; bottom: 0;
    left: 40%;
    width: 1px;
    background: rgba(255,255,255,0.08);
  }

  /* ── Close ───────────────────────────────────────── */
  .jm__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50%;
    cursor: pointer;
    color: rgba(255,255,255,0.5);
    transition: background 0.2s, color 0.2s;
  }
  .jm__close:hover {
    background: rgba(255,255,255,0.12);
    color: #fff;
  }

  /* ── Header ──────────────────────────────────────── */
  .jm__header {
    margin-bottom: 2rem;
  }

  .jm__label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-edificio);
    margin-bottom: 0.625rem;
  }

  .jm__title {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .jm__subtitle {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
  }

  /* ── Form layout ─────────────────────────────────── */
  .jm__form {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .jm__row--two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.875rem;
  }

  @media (max-width: 480px) {
    .jm__row--two { grid-template-columns: 1fr; }
  }

  .jm__field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .jm__label-field {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.02em;
  }

  .jm__label-field span[aria-hidden] {
    color: var(--color-edificio);
  }

  .jm__optional {
    font-weight: 400;
    color: rgba(255,255,255,0.28);
  }

  /* ── Inputs ──────────────────────────────────────── */
  .jm__input,
  .jm__textarea,
  .jm__select {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0;
    color: #fff;
    font-family: inherit;
    font-size: 0.875rem;
    line-height: 1.5;
    padding: 0.625rem 0.875rem;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    -webkit-appearance: none;
    appearance: none;
  }

  .jm__input::placeholder,
  .jm__textarea::placeholder {
    color: rgba(255,255,255,0.2);
  }

  .jm__input:focus,
  .jm__textarea:focus,
  .jm__select:focus {
    border-color: var(--color-edificio);
    background: rgba(255,255,255,0.07);
  }

  .jm__input.is-invalid,
  .jm__textarea.is-invalid,
  .jm__select.is-invalid {
    border-color: #e55;
  }

  .jm__textarea {
    resize: vertical;
    min-height: 80px;
  }

  /* ── Select ──────────────────────────────────────── */
  .jm__select-wrap {
    position: relative;
  }

  .jm__select {
    padding-right: 2.5rem;
    cursor: pointer;
  }

  .jm__select option {
    background: #1a1a1a;
    color: #fff;
  }

  .jm__select-icon {
    position: absolute;
    right: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: rgba(255,255,255,0.35);
  }

  /* ── Status messages ─────────────────────────────── */
  .jm__status {
    font-size: 0.8125rem;
    padding: 0.625rem 0.875rem;
  }

  .jm__status--error {
    background: rgba(220,50,50,0.12);
    border-left: 3px solid #e55;
    color: #ff9090;
  }

  /* ── Actions ─────────────────────────────────────── */
  .jm__actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-top: 0.5rem;
  }

  .jm__submit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-edificio);
    color: #fff;
    border: none;
    padding: 0.75rem 1.5rem;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .jm__submit:hover   { opacity: 0.88; }
  .jm__submit:disabled { opacity: 0.5; cursor: not-allowed; }

  .jm__cancel {
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.35);
    font-family: inherit;
    font-size: 0.8125rem;
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s;
  }
  .jm__cancel:hover { color: rgba(255,255,255,0.7); }

  /* ── Spinner ─────────────────────────────────────── */
  .jm__spinner {
    animation: jm-spin 0.8s linear infinite;
  }
  @keyframes jm-spin { to { transform: rotate(360deg); } }

  /* ── Success state ───────────────────────────────── */
  .jm__success {
    text-align: center;
    padding: 2rem 0 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.875rem;
  }

  .jm__success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(var(--color-parque-rgb, 74,222,128), 0.12);
    border: 1px solid rgba(74,222,128,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4ade80;
  }

  .jm__success-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 800;
    color: #fff;
  }

  .jm__success-body {
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255,255,255,0.5);
    max-width: 340px;
  }

  /* ── Mobile panel ────────────────────────────────── */
  @media (max-width: 600px) {
    .jm__panel {
      padding: 2rem 1.5rem 1.5rem;
      max-height: 96dvh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .jm__panel { animation: none; }
    .jm__spinner { animation: none; }
  }
</style>

<script>
  (function () {
    const modal   = document.getElementById('join-modal')    as HTMLElement;
    const overlay = document.getElementById('jm-overlay')    as HTMLElement;
    const closeBtn= document.getElementById('jm-close')      as HTMLButtonElement;
    const cancelBtn=document.getElementById('jm-cancel')     as HTMLButtonElement;
    const successClose=document.getElementById('jm-success-close') as HTMLButtonElement;
    const form    = document.getElementById('join-form')     as HTMLFormElement;
    const submitBtn=document.getElementById('jm-submit')     as HTMLButtonElement;
    const submitLabel=document.getElementById('jm-submit-label') as HTMLElement;
    const spinner = document.getElementById('jm-spinner')    as HTMLElement;
    const errorEl = document.getElementById('jm-error')      as HTMLElement;
    const successEl=document.getElementById('jm-success')    as HTMLElement;

    if (!modal || !form) return;

    let previousFocus: HTMLElement | null = null;

    // ── Open / Close ────────────────────────────────
    function openModal() {
      previousFocus = document.activeElement as HTMLElement;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      // Focus primer campo
      const first = form.querySelector<HTMLElement>('input,select,textarea');
      first?.focus();
    }

    function closeModal() {
      modal.hidden = true;
      document.body.style.overflow = '';
      previousFocus?.focus();
      // Reset form state
      form.hidden    = false;
      successEl.hidden = true;
      errorEl.hidden   = true;
      form.reset();
      form.querySelectorAll('.is-invalid').forEach(el => el.classList.remove('is-invalid'));
      setLoading(false);
    }

    // ── Triggers ─────────────────────────────────────
    document.querySelectorAll('[data-join-trigger]').forEach(el => {
      el.addEventListener('click', openModal);
    });

    overlay?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    cancelBtn?.addEventListener('click', closeModal);
    successClose?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    // ── Loading state ─────────────────────────────────
    function setLoading(loading: boolean) {
      submitBtn.disabled = loading;
      submitLabel.textContent = loading ? 'Enviando…' : 'Enviar solicitud';
      spinner.hidden = !loading;
    }

    // ── Validate ──────────────────────────────────────
    function validate(): boolean {
      let ok = true;
      form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
        '[required]'
      ).forEach(field => {
        const empty = !field.value.trim();
        field.classList.toggle('is-invalid', empty);
        if (empty) ok = false;
      });
      return ok;
    }

    // ── Submit ────────────────────────────────────────
    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      if (!validate()) return;

      const endpoint = form.dataset.endpoint ?? '';
      if (!endpoint || endpoint.includes('YOUR_FORM_ID')) {
        errorEl.textContent = 'Configura tu Form ID de Formspree en el archivo .env (PUBLIC_FORMSPREE_ID).';
        errorEl.hidden = false;
        return;
      }

      setLoading(true);
      errorEl.hidden = true;

      const data: Record<string, string> = {};
      new FormData(form).forEach((v, k) => { data[k] = v as string; });

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.hidden      = true;
          successEl.hidden = false;
        } else {
          const json = await res.json().catch(() => ({}));
          errorEl.textContent = (json as any)?.errors?.[0]?.message ?? 'Error al enviar. Intenta de nuevo.';
          errorEl.hidden = false;
          setLoading(false);
        }
      } catch {
        errorEl.textContent = 'Sin conexión. Revisa tu red e intenta de nuevo.';
        errorEl.hidden = false;
        setLoading(false);
      }
    });
  })();
</script>
