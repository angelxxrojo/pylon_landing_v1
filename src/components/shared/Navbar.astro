---
import { NAV_LINKS } from '@/constants/navigation';
---

<header id="navbar" class="navbar">
  <div class="navbar__inner">

    <!-- Logo -->
    <a href="/" class="navbar__logo" aria-label="Pylon inicio">
      <div class="navbar__logo-mark">P</div>
      <span class="navbar__logo-name">Pylon</span>
    </a>

    <!-- Desktop nav -->
    <nav class="navbar__links" aria-label="Navegación principal">
      {NAV_LINKS.map(link => (
        <a href={link.href} class="navbar__link">{link.label}</a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-toggle" class="navbar__hamburger" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="navbar__drawer" hidden>
    <nav aria-label="Menú móvil">
      {NAV_LINKS.map(link => (
        <a href={link.href} class="navbar__drawer-link">{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 40;
    /* transitions para el scroll */
    transition:
      background-color 0.4s ease,
      backdrop-filter  0.4s ease,
      -webkit-backdrop-filter 0.4s ease,
      box-shadow       0.4s ease,
      border-color     0.4s ease;
    background-color: transparent;
    border-bottom: 1px solid transparent;
  }

  /* Estado scrolled — añadido por JS */
  .navbar--scrolled {
    background-color: rgba(26, 26, 26, 0.88);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    border-bottom-color: rgba(255, 255, 255, 0.07);
    box-shadow: 0 1px 32px rgba(0, 0, 0, 0.35);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 2rem 1rem 2.5rem;
    min-height: 64px;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .navbar__logo-mark {
    width: 34px;
    height: 34px;
    background: var(--color-edificio);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: #fff;
  }

  .navbar__logo-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
  }

  .navbar__links {
    display: none;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .navbar__link {
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .navbar__link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  .navbar__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 48px;
    height: 48px;
    background: none;
    border: none;
    cursor: pointer;
    margin-left: auto;
    padding: 0 10px;
  }

  .navbar__hamburger span {
    display: block;
    height: 2px;
    background: rgba(255, 255, 255, 0.85);
    border-radius: 2px;
    transition: all 0.2s;
  }

  /* Hamburger → X animation */
  .navbar__hamburger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .navbar__hamburger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .navbar__hamburger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .navbar__drawer {
    background: rgba(18, 18, 18, 0.97);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: 1rem 1.25rem 1.5rem;
  }

  .navbar__drawer-link {
    display: block;
    padding: 0.75rem 0;
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 768px) {
    .navbar__links     { display: flex; }
    .navbar__hamburger { display: none; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar')!;
  const toggle = document.getElementById('menu-toggle')!;
  const drawer = document.getElementById('mobile-menu')!;
  const links  = drawer.querySelectorAll('a');

  /* ── Scroll: transparent → scrolled ── */
  const THRESHOLD = 72; // px antes de que se active

  const syncNav = () => {
    navbar.classList.toggle('navbar--scrolled', window.scrollY > THRESHOLD);
  };

  window.addEventListener('scroll', syncNav, { passive: true });
  syncNav(); // run on load (por si recargas a mitad de página)

  /* ── Mobile menu ── */
  toggle.addEventListener('click', () => {
    const isOpen = !drawer.hidden;
    drawer.hidden = isOpen;
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  links.forEach(link => {
    link.addEventListener('click', () => {
      drawer.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>
